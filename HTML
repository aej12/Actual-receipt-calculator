<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>2026 연봉 실수령 계산기</title>
    <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.8/dist/web/variable/pretendardvariable.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --point-color: #FF7A00;
            --bg-color: #F2F4F6;
            --card-bg: #FFFFFF;
            --text-main: #191F28;
            --text-sub: #8B95A1;
            --border-color: #E5E8EB;
        }

        body {
            font-family: 'Pretendard Variable', Pretendard, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 20px 0;
            display: flex;
            justify-content: center;
        }

        .container {
            width: 100%;
            max-width: 480px;
            background-color: var(--card-bg);
            padding: 30px 24px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            border-radius: 24px;
            position: relative;
            box-sizing: border-box;
        }

        h1 { font-size: 24px; font-weight: 700; margin-bottom: 8px; }
        .subtitle { color: var(--text-sub); font-size: 15px; margin-bottom: 30px; }

        .input-wrapper { position: relative; display: flex; align-items: center; margin-bottom: 24px; }
        input[type="number"] {
            width: 100%; font-size: 24px; font-weight: 600; border: none;
            border-bottom: 2px solid var(--border-color); padding: 10px 0; outline: none;
        }
        input[type="number"]:focus { border-bottom: 2px solid var(--point-color); }
        .unit { position: absolute; right: 0; font-size: 20px; font-weight: 600; }

        .btn-submit {
            width: 100%; background-color: var(--point-color); color: white;
            border: none; border-radius: 12px; padding: 18px;
            font-size: 16px; font-weight: 600; cursor: pointer;
        }

        /* 광고 화면 스타일 */
        #ad-overlay {
            display: none; flex-direction: column; align-items: center; justify-content: center;
            text-align: center; padding: 40px 0;
        }
        .ad-btn {
            display: inline-block; background-color: #0073E6; color: white;
            text-decoration: none; padding: 12px 24px; border-radius: 8px;
            font-weight: 600; margin-top: 20px; margin-bottom: 10px;
        }
        .ad-notice { font-size: 12px; color: #ADB5BD; margin-top: 15px; line-height: 1.4; }

        /* 결과 스타일 */
        #result-screen { display: none; }
        .result-header {
            background-color: var(--bg-color); border-radius: 16px;
            padding: 24px; text-align: center; margin-bottom: 24px;
        }
        .amount { font-size: 32px; font-weight: 700; color: var(--point-color); margin: 8px 0; }
        
        .detail-row {
            display: flex; justify-content: space-between; padding: 14px 0;
            border-bottom: 1px solid var(--border-color); font-size: 14px;
        }
        .label-desc { font-size: 11px; color: var(--text-sub); margin-top: 2px; }
        
        .median-section { margin-top: 40px; border-top: 8px solid var(--bg-color); pt: 20px; }
        .table-scroll { width: 100%; overflow-x: auto; margin-top: 15px; border: 1px solid var(--border-color); border-radius: 8px; }
        table { width: 100%; min-width: 500px; border-collapse: collapse; font-size: 12px; }
        th, td { padding: 10px; border-bottom: 1px solid var(--border-color); text-align: right; }
        th { background: #f9f9f9; text-align: center; }

        .loader {
            border: 3px solid #f3f3f3; border-top: 3px solid var(--point-color);
            border-radius: 50%; width: 30px; height: 30px; animation: spin 1s linear infinite; margin-bottom: 15px;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

    <div class="container">
        <div id="input-screen">
            <h1>2026년 연봉 실수령액</h1>
            <p class="subtitle">나의 세후 월급을 확인해보세요.</p>
            <div class="input-wrapper">
                <input type="number" id="salary-input" placeholder="연봉 입력">
                <span class="unit">만원</span>
            </div>
            <button class="btn-submit" onclick="startCalc()">계산하기</button>
        </div>

        <div id="ad-overlay">
            <div class="loader"></div>
            <h2 style="font-size: 20px;">결과 분석 중...</h2>
            <p style="font-size: 14px; color: var(--text-sub);">더 정확한 계산을 위해 잠시 기다려주세요.</p>
            
            <a href="https://link.coupang.com/a/d3jyTd" target="_blank" class="ad-btn">쿠팡에서 최저가 확인하기</a>
            <p class="ad-notice">쿠팡 파트너스 활동의 일환으로<br>소정의 수수료가 발생할 수 있습니다.</p>
        </div>

        <div id="result-screen">
            <h1>계산 결과</h1>
            <div class="result-header">
                <div style="font-size: 14px; color: var(--text-sub);">예상 실수령액(월)</div>
                <div class="amount" id="net-pay">0원</div>
                <div id="gross-pay" style="font-size: 13px; color: var(--text-sub);">월 소득액 0원</div>
            </div>

            <div class="detail-row">
                <div>
                    <div style="font-weight: 600;">국민연금</div>
                    <div class="label-desc">4.75% (최저 40만 / 최고 637만)</div>
                </div>
                <div id="tax-pension">0원</div>
            </div>
            <div class="detail-row">
                <div>
                    <div style="font-weight: 600;">건강보험</div>
                    <div class="label-desc">3.595%</div>
                </div>
                <div id="tax-health">0원</div>
            </div>
            <div class="detail-row">
                <div>
                    <div style="font-weight: 600;">장기요양</div>
                    <div class="label-desc">건강보험료의 13.14%</div>
                </div>
                <div id="tax-care">0원</div>
            </div>
            <div class="detail-row">
                <div>
                    <div style="font-weight: 600;">고용보험</div>
                    <div class="label-desc">0.9%</div>
                </div>
                <div id="tax-emp">0원</div>
            </div>
            <div class="detail-row">
                <div><div style="font-weight: 600;">근로소득세</div></div>
                <div id="tax-income">0원</div>
            </div>
            <div class="detail-row">
                <div><div style="font-weight: 600;">지방소득세</div></div>
                <div id="tax-local">0원</div>
            </div>

            <div class="detail-row" style="border:none; margin-top:10px; color: var(--point-color); font-weight: 700;">
                <span>시급 (209시간 기준)</span>
                <span id="hourly-wage">0원</span>
            </div>

            <div class="median-section">
                <h3 style="font-size: 16px;">기준중위소득 정보</h3>
                <canvas id="incomeChart" style="max-height: 200px;"></canvas>
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr><th>구분</th><th>1인</th><th>2인</th><th>3인</th><th>4인</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>생계(30%)</td><td>769,271</td><td>1,259,788</td><td>1,607,711</td><td>1,948,421</td></tr>
                            <tr><td>의료(40%)</td><td>1,025,695</td><td>1,679,717</td><td>2,143,614</td><td>2,597,895</td></tr>
                            <tr style="background:#fffcf5;"><td>100%</td><td>2,564,238</td><td>4,199,292</td><td>5,359,036</td><td>6,494,738</td></tr>
                            <tr><td>150%</td><td>3,846,357</td><td>6,298,938</td><td>8,038,554</td><td>9,742,107</td></tr>
                        </tbody>
                    </table>
                </div>
                <p class="ad-notice" style="text-align: center;">쿠팡 파트너스 활동의 일환으로 소정의 수수료가 발생할 수 있습니다.</p>
            </div>

            <button class="btn-submit" style="background:#eee; color:#666; margin-top:20px;" onclick="resetCalc()">다시 계산</button>
        </div>
    </div>

    <script>
        let myChart = null;

        function startCalc() {
            const annual = document.getElementById('salary-input').value;
            if(!annual) return alert("연봉을 입력해주세요.");

            const hasSeenAd = sessionStorage.getItem('viewedAd');
            if (!hasSeenAd) {
                document.getElementById('input-screen').style.display = 'none';
                document.getElementById('ad-overlay').style.display = 'flex';
                setTimeout(() => {
                    sessionStorage.setItem('viewedAd', 'true');
                    document.getElementById('ad-overlay').style.display = 'none';
                    showResults(annual * 10000);
                }, 5000);
            } else {
                document.getElementById('input-screen').style.display = 'none';
                showResults(annual * 10000);
            }
        }

        function showResults(annual) {
            const monthlyGross = Math.floor(annual / 12);
            const pensionBase = Math.max(400000, Math.min(monthlyGross, 6370000));
            const pension = Math.floor(pensionBase * 0.0475);
            const health = Math.floor(monthlyGross * 0.03595);
            const care = Math.floor(health * 0.1314);
            const emp = Math.floor(monthlyGross * 0.009);
            
            // 단순화된 소득세 로직
            let incomeTax = Math.floor(monthlyGross * 0.03); 
            const localTax = Math.floor(incomeTax * 0.1);
            const netPay = monthlyGross - (pension + health + care + emp + incomeTax + localTax);

            document.getElementById('result-screen').style.display = 'block';
            document.getElementById('net-pay').innerText = netPay.toLocaleString() + '원';
            document.getElementById('gross-pay').innerText = `예상 소득액(월) ${monthlyGross.toLocaleString()}원`;
            document.getElementById('tax-pension').innerText = pension.toLocaleString() + '원';
            document.getElementById('tax-health').innerText = health.toLocaleString() + '원';
            document.getElementById('tax-care').innerText = care.toLocaleString() + '원';
            document.getElementById('tax-emp').innerText = emp.toLocaleString() + '원';
            document.getElementById('tax-income').innerText = incomeTax.toLocaleString() + '원';
            document.getElementById('tax-local').innerText = localTax.toLocaleString() + '원';
            document.getElementById('hourly-wage').innerText = Math.floor(monthlyGross/209).toLocaleString() + '원';

            drawChart();
        }

        function drawChart() {
            const ctx = document.getElementById('incomeChart').getContext('2d');
            if (myChart) myChart.destroy();
            myChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: ['1인', '2인', '3인', '4인'],
                    datasets: [{
                        label: '기준중위소득 100%',
                        data: [2564238, 4199292, 5359036, 6494738],
                        backgroundColor: '#FF7A00'
                    }]
                },
                options: { responsive: true, plugins: { legend: { display: false } } }
            });
        }

        function resetCalc() {
            document.getElementById('result-screen').style.display = 'none';
            document.getElementById('input-screen').style.display = 'block';
        }
    </script>
</body>
</html>
